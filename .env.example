# ═══════════════════════════════════════════════════════════════════════
# Marketing AI – Environment Variables
# For Railway: set these in the Railway dashboard → Variables tab
# For local dev: copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════════════

# ── Database ──
# Railway provides this automatically when you add a PostgreSQL plugin.
# Format: postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/marketing_ai

# ── Redis ──
# Railway provides this automatically when you add a Redis plugin.
REDIS_URL=redis://localhost:6379/0

# ── JWT / Auth ──
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# ── Azure AD OIDC (optional) ──
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_REDIRECT_URI=https://your-app.up.railway.app/admin/auth/azure/callback

# ── Encryption key for tool API secrets (Fernet) ──
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOOL_SECRET_ENCRYPTION_KEY=

# ── Default admin credentials (first-run seed) ──
DEFAULT_ADMIN_EMAIL=admin@localhost
DEFAULT_ADMIN_PASSWORD=changeme123

# ── Salesforce (optional) ──
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_DOMAIN=login

# ── LLM ──
# Supported providers: openai | gemini | anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# ── Gunicorn tuning (optional – set in Railway Variables) ──
# GUNICORN_WORKERS=2
# GUNICORN_TIMEOUT=120
