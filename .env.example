# ── Database ──
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/marketing_ai

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── JWT / Auth ──
JWT_SECRET_KEY="221b9a3890f8e34441e8de5fa639a6cac826a3432274d186a4a6ba139b9de159"
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# ── Azure AD OIDC ──
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_REDIRECT_URI=http://localhost:8000/admin/auth/azure/callback

# ── Encryption key for tool API secrets (Fernet) ──
TOOL_SECRET_ENCRYPTION_KEY=

# ── Default admin credentials (first-run seed) ──
DEFAULT_ADMIN_EMAIL=admin@localhost
DEFAULT_ADMIN_PASSWORD=changeme123

# ── Salesforce ──
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_DOMAIN=login

# ── LLM ──
# Supported providers: openai | gemini | anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# Provider API keys (only the key for your chosen provider is required)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

